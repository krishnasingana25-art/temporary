  <h2 class="section-title">Join the FORME Circle</h2>
  <p>New arrivals and exclusive offers straight to your inbox.</p>
  <div class="form-row">
    <input type="email" placeholder="Your email address"/>
    <button type="button">Subscribe</button>
  </div>
</section>

<footer>
  <div class="footer-logo">FORME</div>
  <ul class="footer-links">
    <li><a href="#">About</a></li>
    <li><a href="#">Shipping</a></li>
    <li><a href="#">Returns</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
  <p class="footer-copy">&#169; 2025 FORME.</p>
</footer>

<!-- ===== PRODUCT MODAL ===== -->
<div class="overlay" id="product-overlay" onclick="closeProductIfOutside(event)">
  <div class="product-modal">
    <button class="modal-close" onclick="closeProduct()">&#10005;</button>
    <div class="modal-img">
      <img src="data:image/png;base64," alt="Graphic Tee"/>
    </div>
    <div class="modal-body">
      <p class="modal-label">New Arrival</p>
      <h2 class="modal-name">Graphic Tee</h2>
      <p class="modal-price">&#8377;650</p>
      <p class="modal-desc">Oversized fit with a bold graphic print. Crafted from 100% premium cotton — cool, comfortable, and effortlessly stylish.</p>
      <div>
        <p class="size-label">Select Size</p>
        <div class="size-grid">
          <button class="size-btn" onclick="selectSize(this)">XS</button>
          <button class="size-btn" onclick="selectSize(this)">S</button>
          <button class="size-btn" onclick="selectSize(this)">M</button>
          <button class="size-btn" onclick="selectSize(this)">L</button>
          <button class="size-btn" onclick="selectSize(this)">XL</button>
          <button class="size-btn" onclick="selectSize(this)">XXL</button>
        </div>
      </div>
      <div>
        <p class="size-label">Quantity</p>
        <div class="qty-row">
          <button class="qty-btn" onclick="changeQty(-1)">&#8722;</button>
          <span class="qty-val" id="qty-display">1</span>
          <button class="qty-btn" onclick="changeQty(1)">&#43;</button>
        </div>
      </div>
      <button class="add-to-cart-btn" id="add-btn" onclick="addToCart()">Add to Bag</button>
      <p style="font-size:.72rem;color:var(--mid);text-align:center;">Free shipping on orders above &#8377;999</p>
    </div>
  </div>
</div>

<!-- ===== CART DRAWER ===== -->
<div class="drawer-bg" id="drawer-bg" onclick="closeCart()"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <h2 class="cart-title">Your Bag</h2>
    <button class="cart-close-btn" onclick="closeCart()">&#10005;</button>
  </div>
  <div class="cart-items" id="cart-items-container"></div>
  <div class="cart-footer" id="cart-footer" style="display:none;">
    <div class="cart-total-row">
      <span class="cart-total-label">Total</span>
      <span class="cart-total-val" id="cart-total">&#8377;0</span>
    </div>
    <button class="checkout-btn" onclick="openCheckout()">Proceed to Checkout</button>
  </div>
</div>

<!-- ===== CHECKOUT MODAL ===== -->
<div class="overlay" id="checkout-overlay" onclick="closeCheckoutIfOutside(event)">
  <div class="checkout-modal" id="checkout-modal">
    <button class="modal-close" onclick="closeCheckout()">&#10005;</button>

    <!-- STEP 1: ADDRESS -->
    <div id="step-address">
      <h2>Checkout</h2>
      <div class="checkout-steps">
        <div class="step active">1. Address</div>
        <div class="step">2. Payment</div>
        <div class="step">3. Confirm</div>
      </div>
      <div class="order-summary" id="order-summary-1"></div>
      <div class="form-group"><label>Full Name</label><input type="text" id="fname" placeholder="Rahul Sharma"/></div>
      <div class="form-group"><label>Email</label><input type="email" id="femail" placeholder="rahul@email.com"/></div>
      <div class="form-group"><label>Phone</label><input type="tel" id="fphone" placeholder="+91 98765 43210"/></div>
      <div class="form-group"><label>Address Line 1</label><input type="text" id="faddr1" placeholder="123, MG Road"/></div>
      <div class="form-group"><label>Address Line 2 (optional)</label><input type="text" id="faddr2" placeholder="Apartment, suite, etc."/></div>
      <div class="form-row-2">
        <div class="form-group"><label>City</label><input type="text" id="fcity" placeholder="Mumbai"/></div>
        <div class="form-group"><label>Pincode</label><input type="text" id="fpin" placeholder="400001"/></div>
      </div>
      <div class="form-group">
        <label>State</label>
        <select id="fstate">
          <option value="">Select state</option>
          <option>Maharashtra</option><option>Delhi</option><option>Karnataka</option>
          <option>Tamil Nadu</option><option>Gujarat</option><option>Rajasthan</option>
          <option>West Bengal</option><option>Uttar Pradesh</option><option>Telangana</option>
          <option>Andhra Pradesh</option><option>Kerala</option><option>Punjab</option>
          <option>Haryana</option><option>Other</option>
        </select>
      </div>
      <div class="form-actions">
        <button class="btn-back" onclick="closeCheckout()">Cancel</button>
        <button class="btn-primary" onclick="goToPayment()">Continue to Payment</button>
      </div>
    </div>

    <!-- STEP 2: PAYMENT -->
    <div id="step-payment" style="display:none;">
      <h2>Payment</h2>
      <div class="checkout-steps">
        <div class="step done">1. Address</div>
        <div class="step active">2. Payment</div>
        <div class="step">3. Confirm</div>
      </div>
      <div class="order-summary" id="order-summary-2"></div>
      <p class="size-label" style="margin-bottom:.8rem;">Choose Payment Method</p>
      <div class="pay-methods">
        <div class="pay-method" onclick="selectPayment(this,'UPI')">UPI</div>
        <div class="pay-method" onclick="selectPayment(this,'Card')">Card</div>
        <div class="pay-method" onclick="selectPayment(this,'Net Banking')">Net Banking</div>
        <div class="pay-method" onclick="selectPayment(this,'COD')">Cash on Delivery</div>
      </div>
      <div id="upi-fields" style="display:none;">
        <div class="form-group"><label>UPI ID</label><input type="text" id="fupi" placeholder="yourname@upi"/></div>
      </div>
      <div id="card-fields" style="display:none;">
        <div class="form-group"><label>Card Number</label><input type="text" id="fcard" placeholder="1234 5678 9012 3456" maxlength="19"/></div>
        <div class="form-row-2">
          <div class="form-group"><label>Expiry</label><input type="text" id="fexpiry" placeholder="MM/YY" maxlength="5"/></div>
          <div class="form-group"><label>CVV</label><input type="text" id="fcvv" placeholder="123" maxlength="3"/></div>
        </div>
        <div class="form-group"><label>Name on Card</label><input type="text" id="fcardname" placeholder="Rahul Sharma"/></div>
      </div>
      <div id="nb-fields" style="display:none;">
        <div class="form-group">
          <label>Select Bank</label>
          <select id="fbank">
            <option value="">Select bank</option>
            <option>SBI</option><option>HDFC</option><option>ICICI</option>
            <option>Axis Bank</option><option>Kotak</option><option>Other</option>
          </select>
        </div>
      </div>
      <div id="cod-info" style="display:none;background:var(--bone);padding:1rem;font-size:.85rem;color:var(--mid);line-height:1.6;">
        Pay in cash when your order is delivered. Extra &#8377;50 COD charge applies.
      </div>
      <div class="form-actions" style="margin-top:1.5rem;">
        <button class="btn-back" onclick="goToAddress()">Back</button>
        <button class="btn-primary" onclick="placeOrder()">Place Order</button>
      </div>
    </div>

    <!-- STEP 3: SUCCESS -->
    <div id="step-success" style="display:none;">
      <div class="success-screen">
        <div class="success-icon">
          <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12" stroke="white"/></svg>
        </div>
        <h3>Order Placed!</h3>
        <p>Thank you for shopping with FORME.<br>You'll receive a confirmation shortly.</p>
        <div class="order-id" id="order-id-display"></div>
        <div id="order-detail-summary" style="text-align:left;background:var(--bone);padding:1.2rem;margin-bottom:1.5rem;font-size:.85rem;"></div>
        <button class="btn-primary" onclick="closeCheckout();clearCart();location.reload();">Continue Shopping</button>
      </div>
    </div>
  </div>
</div>

<script>
// ===== STATE =====
let cart = [];
let selectedSize = null;
let qty = 1;
let selectedPayment = null;

const PRODUCT = {
  name: "Graphic Tee",
  price: 650,
  img: "data:image/png;base64,",
  color: "Army Green"
};

// ===== PRODUCT MODAL =====
function openProduct() {
  document.getElementById("product-overlay").classList.add("open");
  document.body.style.overflow = "hidden";
  qty = 1; selectedSize = null;
  document.getElementById("qty-display").textContent = 1;
  document.querySelectorAll(".size-btn").forEach(b => b.classList.remove("selected"));
}
function closeProduct() {
  document.getElementById("product-overlay").classList.remove("open");
  document.body.style.overflow = "";
}
function closeProductIfOutside(e) {
  if (e.target === document.getElementById("product-overlay")) closeProduct();
}
function selectSize(btn) {
  document.querySelectorAll(".size-btn").forEach(b => b.classList.remove("selected"));
  btn.classList.add("selected");
  selectedSize = btn.textContent;
}
function changeQty(d) {
  qty = Math.max(1, Math.min(10, qty + d));
  document.getElementById("qty-display").textContent = qty;
}
function addToCart() {
  if (!selectedSize) { alert("Please select a size!"); return; }
  const existing = cart.find(i => i.size === selectedSize);
  if (existing) { existing.qty += qty; }
  else { cart.push({ ...PRODUCT, size: selectedSize, qty }); }
  updateCartUI();
  closeProduct();
  openCart();
}

// ===== CART =====
function openCart() {
  document.getElementById("cart-drawer").classList.add("open");
  document.getElementById("drawer-bg").classList.add("open");
  document.body.style.overflow = "hidden";
  renderCart();
}
function closeCart() {
  document.getElementById("cart-drawer").classList.remove("open");
  document.getElementById("drawer-bg").classList.remove("open");
  document.body.style.overflow = "";
}
function removeItem(idx) {
  cart.splice(idx, 1);
  updateCartUI();
  renderCart();
}
function updateCartUI() {
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById("cart-count").textContent = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById("cart-total").textContent = "\u20b9" + total.toLocaleString("en-IN");
}
function renderCart() {
  const container = document.getElementById("cart-items-container");
  const footer = document.getElementById("cart-footer");
  if (cart.length === 0) {
    container.innerHTML = '<div class="cart-empty"><p>Your bag is empty.</p></div>';
    footer.style.display = "none";
    return;
  }
  footer.style.display = "block";
  container.innerHTML = cart.map((item, idx) => `
    <div class="cart-item">
      <img class="cart-item-img" src="${item.img}" alt="${item.name}"/>
      <div class="cart-item-info">
        <p class="cart-item-name">${item.name}</p>
        <p class="cart-item-meta">Size: ${item.size} &nbsp;|&nbsp; Qty: ${item.qty} &nbsp;|&nbsp; ${item.color}</p>
        <p class="cart-item-price">&#8377;${(item.price * item.qty).toLocaleString("en-IN")}</p>
        <button class="cart-item-remove" onclick="removeItem(${idx})">Remove</button>
      </div>
    </div>
  `).join("");
  updateCartUI();
}
function clearCart() { cart = []; updateCartUI(); }

// ===== CHECKOUT =====
function openCheckout() {
  closeCart();
  renderOrderSummary("order-summary-1");
  document.getElementById("checkout-overlay").classList.add("open");
  document.body.style.overflow = "hidden";
  showStep("step-address");
}
function closeCheckout() {
  document.getElementById("checkout-overlay").classList.remove("open");
  document.body.style.overflow = "";
}
function closeCheckoutIfOutside(e) {
  if (e.target === document.getElementById("checkout-overlay")) closeCheckout();
}
function showStep(id) {
  ["step-address","step-payment","step-success"].forEach(s => {
    document.getElementById(s).style.display = s === id ? "block" : "none";
  });
}
function renderOrderSummary(elId) {
  const subtotal = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const shipping = subtotal >= 999 ? 0 : 99;
  const total = subtotal + shipping;
  document.getElementById(elId).innerHTML = `
    <h3>Order Summary</h3>
    ${cart.map(i=>`<div class="order-line"><span>${i.name} (${i.size}) x${i.qty}</span><span>&#8377;${(i.price*i.qty).toLocaleString("en-IN")}</span></div>`).join("")}
    <div class="order-line"><span>Shipping</span><span>${shipping===0?"Free":"&#8377;"+shipping}</span></div>
    <div class="order-line total"><span>Total</span><span>&#8377;${total.toLocaleString("en-IN")}</span></div>
  `;
}
function goToPayment() {
  const required = ["fname","femail","fphone","faddr1","fcity","fpin","fstate"];
  for (let id of required) {
    if (!document.getElementById(id).value.trim()) {
      alert("Please fill in all required fields."); return;
    }
  }
  renderOrderSummary("order-summary-2");
  showStep("step-payment");
}
function goToAddress() { showStep("step-address"); }
function selectPayment(el, method) {
  document.querySelectorAll(".pay-method").forEach(e=>e.classList.remove("selected"));
  el.classList.add("selected");
  selectedPayment = method;
  document.getElementById("upi-fields").style.display = method==="UPI"?"block":"none";
  document.getElementById("card-fields").style.display = method==="Card"?"block":"none";
  document.getElementById("nb-fields").style.display = method==="Net Banking"?"block":"none";
  document.getElementById("cod-info").style.display = method==="COD"?"block":"none";
}
function placeOrder() {
  if (!selectedPayment) { alert("Please select a payment method."); return; }
  const name = document.getElementById("fname").value;
  const city = document.getElementById("fcity").value;
  const subtotal = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const shipping = subtotal>=999?0:99;
  const cod = selectedPayment==="COD"?50:0;
  const total = subtotal+shipping+cod;
  const orderId = "FORME-" + Date.now().toString().slice(-8);
  document.getElementById("order-id-display").textContent = "Order ID: " + orderId;
  document.getElementById("order-detail-summary").innerHTML = `
    <strong style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;">Delivery to</strong><br>
    <span style="color:var(--mid)">${name}, ${city}</span><br><br>
    <strong style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;">Items</strong><br>
    ${cart.map(i=>`<span style="color:var(--mid)">${i.name} (${i.size}) x${i.qty} — &#8377;${(i.price*i.qty).toLocaleString("en-IN")}</span>`).join("<br>")}
    <br><br>
    <strong>Total Paid: &#8377;${total.toLocaleString("en-IN")}</strong> via ${selectedPayment}
  `;
  showStep("step-success");
}

// ===== SCROLL REVEAL =====
const reveals = document.querySelectorAll(".reveal");
const observer = new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add("visible");});
},{threshold:0.1});
reveals.forEach(el=>observer.observe(el));

// Card number formatting
document.addEventListener("input", e => {
  if (e.target.id === "fcard") {
    let v = e.target.value.replace(/\D/g,"").substring(0,16);
    e.target.value = v.replace(/(\d{4})/g,"$1 ").trim();
  }
  if (e.target.id === "fexpiry") {
    let v = e.target.value.replace(/\D/g,"").substring(0,4);
    if (v.length>2) v = v.substring(0,2)+"/"+v.substring(2);
    e.target.value = v;
  }
});
</script>
</body>
</html>
