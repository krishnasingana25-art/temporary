<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>FORME — Clothing</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --cream:#f5f2ee;--bone:#ede9e3;--charcoal:#1c1c1c;f
      --mid:#7a7469;--accent:#c9a96e;
    }
    html{scroll-behavior:smooth;}
    body{font-family:"Jost",sans-serif;background:var(--cream);color:var(--charcoal);overflow-x:hidden;}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.5rem 4rem;background:var(--cream);border-bottom:1px solid rgba(0,0,0,0.06);}
    .nav-logo{font-family:"Cormorant Garamond",serif;font-size:1.6rem;font-weight:300;letter-spacing:.2em;}
    .nav-links{display:flex;gap:2.5rem;list-style:none;}
    .nav-links a{font-size:.78rem;font-weight:400;letter-spacing:.15em;text-transform:uppercase;text-decoration:none;color:var(--charcoal);transition:color .2s;}
    .nav-links a:hover{color:var(--accent);}
    .nav-right{display:flex;gap:1.5rem;align-items:center;}
    .nav-icon{font-size:.78rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;color:var(--charcoal);cursor:pointer;transition:color .2s;}
    .nav-icon:hover{color:var(--accent);}
    .cart-btn{position:relative;cursor:pointer;}
    .cart-count{position:absolute;top:-8px;right:-10px;background:var(--accent);color:white;border-radius:50%;width:16px;height:16px;font-size:.6rem;display:flex;align-items:center;justify-content:center;font-weight:500;}

    /* HERO */
    .hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:80px;}
    .hero-text{display:flex;flex-direction:column;justify-content:center;padding:6rem 4rem;animation:fadeUp 1s ease .3s both;}
    .hero-label{font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mid);margin-bottom:2rem;}
    .hero-heading{font-family:"Cormorant Garamond",serif;font-size:clamp(3.5rem,6vw,6rem);font-weight:300;line-height:1.05;margin-bottom:2rem;}
    .hero-heading em{font-style:italic;color:var(--accent);}
    .hero-sub{font-size:.9rem;font-weight:300;color:var(--mid);line-height:1.8;max-width:380px;margin-bottom:3rem;}
    .btn-primary{display:inline-block;padding:1rem 2.5rem;background:var(--charcoal);color:var(--cream);font-family:"Jost",sans-serif;font-size:.75rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:background .3s,transform .2s;align-self:flex-start;cursor:pointer;border:none;}
    .btn-primary:hover{background:var(--accent);transform:translateY(-2px);}
    .btn-outline{display:inline-block;padding:.9rem 2.5rem;border:1px solid var(--charcoal);color:var(--charcoal);font-family:"Jost",sans-serif;font-size:.75rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;transition:all .3s;margin-left:1rem;cursor:pointer;background:none;}
    .btn-outline:hover{background:var(--charcoal);color:var(--cream);}
    .hero-image{background:var(--bone);position:relative;overflow:hidden;}
    .hero-image-inner{width:100%;height:100%;background:linear-gradient(160deg,#e8e2d9 0%,#d4cdc4 100%);display:flex;align-items:center;justify-content:center;}
    .hero-image-tag{position:absolute;bottom:2.5rem;left:2.5rem;background:var(--cream);padding:1rem 1.5rem;font-size:.75rem;letter-spacing:.1em;}
    .hero-image-tag strong{display:block;font-weight:500;margin-bottom:.2rem;}
    .hero-image-tag span{color:var(--mid);}

    /* MARQUEE */
    .marquee-wrap{overflow:hidden;border-top:1px solid rgba(0,0,0,.07);border-bottom:1px solid rgba(0,0,0,.07);padding:1rem 0;background:var(--bone);}
    .marquee-track{display:flex;gap:3rem;width:max-content;animation:marquee 22s linear infinite;}
    .marquee-item{font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mid);white-space:nowrap;display:flex;align-items:center;gap:3rem;}
    .marquee-dot{width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0;}

    /* SECTION */
    .section{padding:7rem 4rem;}
    .section-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:4rem;}
    .section-label{font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mid);margin-bottom:.75rem;}
    .section-title{font-family:"Cormorant Garamond",serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:300;}

    /* PRODUCT GRID */
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
    .product-card{cursor:pointer;}
    .product-img{aspect-ratio:3/4;background:var(--bone);margin-bottom:1.2rem;overflow:hidden;position:relative;transition:transform .4s ease;}
    .product-card:hover .product-img{transform:scale(1.02);}
    .product-img img{width:100%;height:100%;object-fit:cover;display:block;}
    .product-badge{position:absolute;top:1rem;left:1rem;background:var(--charcoal);color:var(--cream);font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;padding:.3rem .7rem;z-index:2;}
    .product-name{font-family:"Cormorant Garamond",serif;font-size:1.1rem;font-weight:400;margin-bottom:.3rem;}
    .product-price{font-size:.82rem;color:var(--mid);letter-spacing:.05em;}
    .product-price strong{color:var(--charcoal);font-weight:400;}
    .swatches{display:flex;gap:.4rem;margin-top:.6rem;}
    .swatch{width:12px;height:12px;border-radius:50%;border:1px solid rgba(0,0,0,.1);}
    .coming-soon-card{opacity:.35;pointer-events:none;}
    .coming-soon-img{aspect-ratio:3/4;background:var(--bone);margin-bottom:1.2rem;display:flex;align-items:center;justify-content:center;}
    .coming-soon-img p{font-family:"Cormorant Garamond",serif;font-size:1.1rem;color:var(--mid);text-align:center;}

    /* FEATURES */
    .features{background:var(--bone);}
    .grid-features{display:grid;grid-template-columns:repeat(3,1fr);gap:3rem;}
    .feature{text-align:center;padding:2rem;}
    .feature-icon{width:48px;height:48px;margin:0 auto 1.5rem;opacity:.5;}
    .feature-title{font-family:"Cormorant Garamond",serif;font-size:1.3rem;font-weight:400;margin-bottom:.75rem;}
    .feature-text{font-size:.85rem;color:var(--mid);line-height:1.8;font-weight:300;}

    /* NEWSLETTER */
    .newsletter{text-align:center;padding:7rem 4rem;}
    .newsletter p{font-size:.9rem;color:var(--mid);margin-bottom:2.5rem;font-weight:300;margin-top:.5rem;}
    .form-row{display:flex;max-width:460px;margin:0 auto;}
    .form-row input{flex:1;padding:1rem 1.5rem;border:1px solid rgba(0,0,0,.15);border-right:none;background:transparent;font-family:"Jost",sans-serif;font-size:.85rem;outline:none;color:var(--charcoal);}
    .form-row input::placeholder{color:var(--mid);}
    .form-row button{padding:1rem 2rem;background:var(--charcoal);color:var(--cream);border:none;cursor:pointer;font-family:"Jost",sans-serif;font-size:.75rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;transition:background .3s;}
    .form-row button:hover{background:var(--accent);}

    /* FOOTER */
    footer{border-top:1px solid rgba(0,0,0,.08);padding:3rem 4rem;display:flex;align-items:center;justify-content:space-between;}
    .footer-logo{font-family:"Cormorant Garamond",serif;font-size:1.2rem;font-weight:300;letter-spacing:.2em;}
    .footer-links{display:flex;gap:2rem;list-style:none;}
    .footer-links a{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);text-decoration:none;transition:color .2s;}
    .footer-links a:hover{color:var(--charcoal);}
    .footer-copy{font-size:.75rem;color:var(--mid);}

    /* === OVERLAY / MODAL BASE === */
    .overlay{position:fixed;inset:0;z-index:500;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.5);opacity:0;pointer-events:none;transition:opacity .3s;}
    .overlay.open{opacity:1;pointer-events:all;}

    /* PRODUCT MODAL */
    .product-modal{background:var(--cream);max-width:860px;width:90%;max-height:90vh;overflow-y:auto;display:grid;grid-template-columns:1fr 1fr;position:relative;animation:slideUp .35s ease both;}
    .modal-img{aspect-ratio:3/4;overflow:hidden;}
    .modal-img img{width:100%;height:100%;object-fit:cover;}
    .modal-body{padding:3rem 2.5rem;display:flex;flex-direction:column;justify-content:center;gap:1rem;}
    .modal-close{position:absolute;top:1.2rem;right:1.5rem;background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--charcoal);z-index:10;font-family:"Jost",sans-serif;}
    .modal-label{font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:var(--mid);}
    .modal-name{font-family:"Cormorant Garamond",serif;font-size:2rem;font-weight:300;line-height:1.1;}
    .modal-price{font-size:1.3rem;font-weight:400;color:var(--charcoal);}
    .modal-desc{font-size:.85rem;color:var(--mid);line-height:1.8;font-weight:300;}
    .size-label{font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;margin-bottom:.5rem;color:var(--mid);}
    .size-grid{display:flex;gap:.5rem;flex-wrap:wrap;}
    .size-btn{width:42px;height:42px;border:1px solid rgba(0,0,0,.2);background:none;cursor:pointer;font-family:"Jost",sans-serif;font-size:.8rem;transition:all .2s;}
    .size-btn:hover{border-color:var(--charcoal);}
    .size-btn.selected{background:var(--charcoal);color:var(--cream);border-color:var(--charcoal);}
    .qty-row{display:flex;align-items:center;gap:.8rem;}
    .qty-btn{width:36px;height:36px;border:1px solid rgba(0,0,0,.2);background:none;cursor:pointer;font-size:1.1rem;font-family:"Jost",sans-serif;transition:all .2s;}
    .qty-btn:hover{border-color:var(--charcoal);}
    .qty-val{font-size:1rem;min-width:24px;text-align:center;}
    .add-to-cart-btn{padding:1rem;background:var(--charcoal);color:var(--cream);border:none;cursor:pointer;font-family:"Jost",sans-serif;font-size:.8rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;transition:background .3s;width:100%;}
    .add-to-cart-btn:hover{background:var(--accent);}
    .add-to-cart-btn:disabled{background:#ccc;cursor:not-allowed;}

    /* CART DRAWER */
    .cart-drawer{position:fixed;top:0;right:0;bottom:0;width:420px;max-width:100vw;background:var(--cream);z-index:600;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .35s ease;box-shadow:-4px 0 30px rgba(0,0,0,.1);}
    .cart-drawer.open{transform:translateX(0);}
    .cart-header{padding:1.5rem 2rem;border-bottom:1px solid rgba(0,0,0,.08);display:flex;align-items:center;justify-content:space-between;}
    .cart-title{font-family:"Cormorant Garamond",serif;font-size:1.5rem;font-weight:300;}
    .cart-close-btn{background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--charcoal);}
    .cart-items{flex:1;overflow-y:auto;padding:1.5rem 2rem;}
    .cart-empty{text-align:center;padding:3rem 0;color:var(--mid);font-size:.9rem;}
    .cart-item{display:flex;gap:1rem;padding:1rem 0;border-bottom:1px solid rgba(0,0,0,.06);}
    .cart-item-img{width:72px;height:96px;object-fit:cover;flex-shrink:0;}
    .cart-item-info{flex:1;}
    .cart-item-name{font-family:"Cormorant Garamond",serif;font-size:1rem;margin-bottom:.2rem;}
    .cart-item-meta{font-size:.75rem;color:var(--mid);margin-bottom:.4rem;}
    .cart-item-price{font-size:.9rem;font-weight:500;}
    .cart-item-remove{background:none;border:none;color:var(--mid);cursor:pointer;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;padding:0;margin-top:.4rem;}
    .cart-item-remove:hover{color:var(--charcoal);}
    .cart-footer{padding:1.5rem 2rem;border-top:1px solid rgba(0,0,0,.08);}
    .cart-total-row{display:flex;justify-content:space-between;margin-bottom:1.5rem;}
    .cart-total-label{font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);}
    .cart-total-val{font-size:1.1rem;font-weight:500;}
    .checkout-btn{width:100%;padding:1rem;background:var(--charcoal);color:var(--cream);border:none;cursor:pointer;font-family:"Jost",sans-serif;font-size:.8rem;font-weight:500;letter-spacing:.2em;text-transform:uppercase;transition:background .3s;}
    .checkout-btn:hover{background:var(--accent);}

    /* CHECKOUT MODAL */
    .checkout-modal{background:var(--cream);max-width:600px;width:90%;max-height:90vh;overflow-y:auto;padding:3rem;position:relative;animation:slideUp .35s ease both;}
    .checkout-modal h2{font-family:"Cormorant Garamond",serif;font-size:2rem;font-weight:300;margin-bottom:2rem;}
    .checkout-steps{display:flex;gap:1rem;margin-bottom:2.5rem;}
    .step{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--mid);padding:.4rem .8rem;border:1px solid rgba(0,0,0,.1);}
    .step.active{background:var(--charcoal);color:var(--cream);border-color:var(--charcoal);}
    .step.done{border-color:var(--accent);color:var(--accent);}
    .form-group{margin-bottom:1.2rem;}
    .form-group label{display:block;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mid);margin-bottom:.4rem;}
    .form-group input,.form-group select{width:100%;padding:.8rem 1rem;border:1px solid rgba(0,0,0,.15);background:transparent;font-family:"Jost",sans-serif;font-size:.9rem;outline:none;color:var(--charcoal);transition:border-color .2s;}
    .form-group input:focus,.form-group select:focus{border-color:var(--charcoal);}
    .form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    .order-summary{background:var(--bone);padding:1.5rem;margin-bottom:1.5rem;}
    .order-summary h3{font-family:"Cormorant Garamond",serif;font-size:1.1rem;font-weight:400;margin-bottom:1rem;}
    .order-line{display:flex;justify-content:space-between;font-size:.85rem;margin-bottom:.5rem;color:var(--mid);}
    .order-line.total{color:var(--charcoal);font-weight:500;font-size:.95rem;border-top:1px solid rgba(0,0,0,.1);padding-top:.8rem;margin-top:.8rem;}
    .pay-methods{display:flex;gap:.8rem;margin-bottom:1.5rem;flex-wrap:wrap;}
    .pay-method{flex:1;min-width:100px;padding:.8rem;border:1px solid rgba(0,0,0,.15);text-align:center;cursor:pointer;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;transition:all .2s;}
    .pay-method:hover,.pay-method.selected{border-color:var(--charcoal);background:var(--charcoal);color:var(--cream);}
    .btn-back{background:none;border:1px solid rgba(0,0,0,.2);padding:.8rem 1.5rem;cursor:pointer;font-family:"Jost",sans-serif;font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;margin-right:1rem;transition:all .2s;}
    .btn-back:hover{border-color:var(--charcoal);}
    .form-actions{display:flex;align-items:center;margin-top:1.5rem;}
    .success-screen{text-align:center;padding:2rem 0;}
    .success-icon{width:64px;height:64px;border-radius:50%;background:var(--charcoal);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;}
    .success-icon svg{stroke:white;}
    .success-screen h3{font-family:"Cormorant Garamond",serif;font-size:2rem;font-weight:300;margin-bottom:.5rem;}
    .success-screen p{color:var(--mid);font-size:.9rem;line-height:1.8;margin-bottom:2rem;}
    .order-id{font-family:monospace;background:var(--bone);padding:.4rem .8rem;font-size:.8rem;display:inline-block;margin-bottom:1rem;}

    /* ANIMATIONS */
    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
    @keyframes fadeDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
    @keyframes slideUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease;}
    .reveal.visible{opacity:1;transform:translateY(0);}

    .drawer-bg{position:fixed;inset:0;z-index:590;background:rgba(0,0,0,.4);opacity:0;pointer-events:none;transition:opacity .3s;}
    .drawer-bg.open{opacity:1;pointer-events:all;}
  </style>
</head>
